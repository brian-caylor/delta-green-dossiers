rules_version = '2';

// Delta Green Dossiers — Firestore security rules.
//
// Current scope: a user can read/write only their own character docs.
// Structured so future Handler/Campaign read rules drop in alongside
// without touching the owner rule below.

service cloud.firestore {
  match /databases/{database}/documents {

    match /characters/{charId} {
      // List + get. For list operations, Firestore must prove the query
      // filter is at least as restrictive as the rule, so the client's
      // where("userId", "==", auth.uid) clause is what makes the query
      // succeed. Inlined (no helper function) so the analyzer can resolve
      // it reliably.
      allow list: if request.auth != null
                  && request.auth.uid == resource.data.userId;
      allow get:  if request.auth != null
                  && request.auth.uid == resource.data.userId;

      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.userId
                    && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.userId;
    }

    match /profiles/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
